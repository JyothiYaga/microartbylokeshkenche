---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollRevealText from '../../components/ScrollRevealText.astro';
import artworks from '../../data/artworks.json';

// Static path generation for all artworks
export function getStaticPaths() {
  return artworks.map(artwork => ({
    params: { slug: artwork.slug },
    props: { artwork }
  }));
}

interface Artwork {
  id: number;
  slug: string;
  title: string;
  description: string;
  image: string;
  year: string;
  medium: string;
}

const { artwork } = Astro.props as { artwork: Artwork };

// Find previous and next artworks for navigation
const currentIndex = artworks.findIndex(a => a.slug === artwork.slug);
const prevArtwork = currentIndex > 0 ? artworks[currentIndex - 1] : null;
const nextArtwork = currentIndex < artworks.length - 1 ? artworks[currentIndex + 1] : null;
---

<BaseLayout title={`${artwork.title} – Lokesh Kenche`}>
  
  <!-- Simple header for detail pages -->
  <header class="fixed top-0 left-0 right-0 z-40 bg-stone-50/90 backdrop-blur-sm border-b border-stone-100">
    <div class="content-width section-padding-x py-4 flex justify-between items-center">
      <a 
        href="/" 
        class="text-lg font-serif font-light text-stone-800 tracking-wide hover:text-stone-600 transition-colors"
      >
        Lokesh Kenche
      </a>
      <a 
        href="/#gallery" 
        class="text-xs uppercase tracking-widest text-stone-500 hover:text-stone-900 transition-colors"
      >
        Back to Gallery
      </a>
    </div>
  </header>
  
  <div class="h-16" aria-hidden="true"></div>
  
  <article class="min-h-screen section-padding">
    <div class="content-width">
      
      <!-- Back navigation -->
      <a 
        href="/#gallery"
        class="inline-flex items-center gap-2 text-sm text-stone-500 hover:text-stone-900 mb-10 transition-colors duration-300"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Gallery
      </a>
      
      <!-- Artwork display - exhibition style -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
        
        <!-- Artwork image -->
        <ScrollRevealText>
          <div class="aspect-square bg-stone-100 overflow-hidden">
            <img 
              src={artwork.image}
              alt={artwork.title}
              class="w-full h-full object-cover"
            />
          </div>
        </ScrollRevealText>
        
        <!-- Exhibition label - like a museum placard -->
        <div class="space-y-6 md:sticky md:top-32">
          <ScrollRevealText delay={0.1}>
            <div>
              <h1 class="text-3xl md:text-4xl font-light font-serif text-stone-800 mb-2">
                {artwork.title}
              </h1>
              <p class="text-stone-500 text-sm">{artwork.year}</p>
            </div>
          </ScrollRevealText>
          
          <ScrollRevealText delay={0.2}>
            <div class="h-px bg-stone-200 w-16" aria-hidden="true" />
          </ScrollRevealText>
          
          <ScrollRevealText delay={0.3}>
            <p class="text-lg leading-relaxed text-stone-700">
              {artwork.description}
            </p>
          </ScrollRevealText>
          
          <ScrollRevealText delay={0.4}>
            <div class="pt-6 space-y-3">
              <p class="text-xs text-stone-500 uppercase tracking-widest">Medium</p>
              <p class="text-base text-stone-700">{artwork.medium}</p>
            </div>
          </ScrollRevealText>
          
          <!-- Prev/Next navigation -->
          <ScrollRevealText delay={0.5}>
            <div class="pt-8 flex justify-between items-center border-t border-stone-200 mt-8">
              {prevArtwork ? (
                <a 
                  href={`/gallery/${prevArtwork.slug}`}
                  class="text-sm text-stone-500 hover:text-stone-900 transition-colors"
                >
                  ← {prevArtwork.title}
                </a>
              ) : <span />}
              
              {nextArtwork ? (
                <a 
                  href={`/gallery/${nextArtwork.slug}`}
                  class="text-sm text-stone-500 hover:text-stone-900 transition-colors"
                >
                  {nextArtwork.title} →
                </a>
              ) : <span />}
            </div>
          </ScrollRevealText>
        </div>
        
      </div>
    </div>
  </article>
</BaseLayout>