---
/**
 * Gallery Card Component
 * 
 * Displays artwork in the gallery grid.
 * On hover:
 * - Other artworks subtly blur and dim (handled by CSS :has())
 * - This artwork shows title and info icon
 * - Subtle scale effect for depth
 */
interface Props {
  artwork: {
    slug: string;
    title: string;
    image: string;
    year: string;
  };
  index?: number;
}

const { artwork, index = 0 } = Astro.props;
const exhibitionNumber = String(index + 1).padStart(2, '0');
---

<a
  href={`/gallery/${artwork.slug}`}
  class="gallery-card group relative block aspect-square overflow-hidden bg-stone-100 cursor-crosshair"
>
  <!-- Artwork image -->
  <img 
    src={artwork.image}
    alt={artwork.title}
    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
    loading="lazy"
    decoding="async"
  />
  
  <!-- Gradient overlay — rich bottom fade -->
  <div class="card-overlay absolute inset-0 transition-opacity duration-500 opacity-0 group-hover:opacity-100" />

  <!-- Centered "View" text on hover -->
  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-400 card-view-text">
    <span class="text-sm font-serif italic text-stone-100 tracking-[0.3em] uppercase">View</span>
  </div>

  <!-- Title reveal on hover -->
  <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out border-l-2 border-[#C4A882]/0 group-hover:border-[#C4A882]/70">
    <p class="text-[10px] uppercase tracking-widest font-sans mb-1" style="color: rgba(196,168,130,0.85);">No. {exhibitionNumber}</p>
    <h3 class="text-white text-base font-light font-serif tracking-wide drop-shadow-lg">
      {artwork.title}
    </h3>
    <p class="text-white/50 text-xs mt-1 tracking-widest">{artwork.year}</p>
  </div>
</a>

<style>
  .gallery-card {
    transition: filter 0.5s cubic-bezier(0.4, 0.0, 0.2, 1);
  }

  .card-overlay {
    background: linear-gradient(
      to top,
      rgba(10, 9, 8, 0.88) 0%,
      rgba(10, 9, 8, 0.4) 40%,
      transparent 70%
    );
  }

  .card-view-text {
    transform: translateY(4px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .group:hover .card-view-text {
    transform: translateY(0);
  }

  /*
   * When ANY card in the grid is hovered, blur all OTHER cards.
   * Pure-CSS hover effect using :has() selector.
   */
  .gallery-grid:has(.gallery-card:hover) .gallery-card:not(:hover) {
    filter: blur(3px) brightness(0.55);
  }
</style>