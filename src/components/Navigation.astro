---
/**
 * Navigation Component
 * Minimal, contextual navigation that only appears on inner pages.
 * Follows the "exhibition" aesthetic - unobtrusive, present when needed.
 */
interface Props {
  current?: string;
}

const { current } = Astro.props;

const links = [
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/words', label: 'Words' },
  { href: '/contact', label: 'Contact' }
];
---

<nav class="fixed top-0 left-0 right-0 z-40 py-5 px-6 md:px-8 bg-stone-50/80 backdrop-blur-sm">
  <div class="flex justify-between items-center max-w-7xl mx-auto">
    <!-- Logo/Home link -->
    <a 
      href="/" 
      class="text-sm tracking-widest uppercase font-light text-stone-700 hover:text-stone-900 transition-colors duration-300"
    >
      Lokesh Kenche
    </a>
    
    <!-- Navigation links -->
    <div class="hidden sm:flex gap-6 md:gap-8">
      {links.map(link => (
        <a 
          href={link.href}
          class:list={[
            "text-xs tracking-wider uppercase transition-colors duration-300",
            current === link.href 
              ? "text-stone-900" 
              : "text-stone-500 hover:text-stone-900"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    
    <!-- Mobile menu button -->
    <button 
      id="mobile-menu-toggle"
      class="sm:hidden p-2 -mr-2 text-stone-600"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden mt-4 pb-2">
    <div class="flex flex-col gap-4 pt-4 border-t border-stone-200">
      {links.map(link => (
        <a 
          href={link.href}
          class:list={[
            "text-sm tracking-wider uppercase transition-colors duration-300",
            current === link.href 
              ? "text-stone-900" 
              : "text-stone-500"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<!-- Spacer to prevent content from hiding under fixed nav -->
<div class="h-16" aria-hidden="true"></div>

<script>
  // Simple mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
