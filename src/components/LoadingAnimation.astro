---
/**
 * Loading Animation Component
 *
 * Minimal typewriter effect that reveals "Microart" letter-by-letter
 * using GSAP staggered animation, then fades out to the hero section.
 */
---

<div id="loading-screen" class="loading-overlay" aria-hidden="true">
  <div class="loading-content">
    <span id="typewriter-text" class="typewriter-word" aria-label="Microart"
      ><span class="typewriter-letter">M</span><span class="typewriter-letter"
        >i</span
      ><span class="typewriter-letter">c</span><span class="typewriter-letter"
        >r</span
      ><span class="typewriter-letter">o</span><span class="typewriter-letter"
        >a</span
      ><span class="typewriter-letter">r</span><span class="typewriter-letter"
        >t</span
      ></span
    >
    <div id="loading-gold-line" class="loading-gold-line" aria-hidden="true"></div>
  </div>
</div>

<style>
  .loading-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: #0C0B0A; /* pure graphite */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .typewriter-word {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: 0.08em;
    color: #EDE8DF;
    line-height: 1;
    display: inline-flex;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .typewriter-letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    will-change: opacity, transform;
  }

  .loading-gold-line {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C4A882, transparent);
    transform: scaleX(0);
    transform-origin: center;
    will-change: transform;
  }
</style>

<script>
  import gsap from "gsap";

  const loadingScreen = document.getElementById("loading-screen");
  const letters = document.querySelectorAll(".typewriter-letter");

  const goldLine = document.getElementById("loading-gold-line");

  if (loadingScreen && letters.length > 0) {
    const tl = gsap.timeline();

    // Initial pause — let the screen breathe
    tl.to({}, { duration: 0.4 });

    // Reveal letters one by one — slow, deliberate cadence
    tl.to(letters, {
      opacity: 1,
      y: 0,
      duration: 0.28,
      stagger: 0.2,
      ease: "power2.out",
    });

    // Gold accent line draws in beneath the word
    if (goldLine) {
      tl.to(goldLine, {
        scaleX: 1,
        duration: 0.6,
        ease: "power2.inOut",
      }, "-=0.1");
    }

    // Hold the completed word — let it settle
    tl.to({}, { duration: 0.9 });

    // Curtain lifts upward — clip-path reveal
    tl.to(loadingScreen, {
      clipPath: "inset(0 0 100% 0)",
      duration: 0.75,
      ease: "power3.inOut",
      onComplete: () => {
        loadingScreen.style.visibility = "hidden";
        loadingScreen.style.pointerEvents = "none";
        loadingScreen.remove();
      },
    });
  }
</script>
